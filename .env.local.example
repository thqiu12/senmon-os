# データベース設定
DATABASE_URL="file:./dev.db"

# セッションシークレット（必須・32文字以上）
# 生成例: openssl rand -hex 32
SESSION_SECRET=""

# CSRFシークレット（任意。未設定時は SESSION_SECRET を流用）
CSRF_SECRET=""

# 管理画面の公開URL（メール内リンクに使用）
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# 通知メール
RESEND_API_KEY=""
RESEND_FROM=""
ADMIN_EMAIL=""

# SMTP（nodemailer 使用時）
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# アップロード（プライベートディレクトリ。デフォルト: private/uploads）
UPLOAD_DIR="private/uploads"
MAX_FILE_SIZE_MB="10"

# 信頼するプロキシヘッダ名（X-Real-IP 推奨）
TRUSTED_PROXY_HEADER="x-real-ip"

# 初期管理者シード（npm run db:seed 用）
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD=""
